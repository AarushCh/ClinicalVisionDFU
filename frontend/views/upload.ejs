<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/css/style.css">
    <title>DFU Detection - Upload</title>
</head>
<body>
    <div class="container">
        <h2>Patient Data & Image Upload</h2>
        <form action="/analyze" method="POST" enctype="multipart/form-data">
            <div class="input-group">
                <label>Foot Image (Plantar View):</label>
                <input type="file" name="image" accept="image/*" required>
            </div>
            <div class="input-group">
                <label>Age:</label>
                <input type="number" name="age" required>
            </div>
            <div class="input-group">
                <label>BMI:</label>
                <input type="number" step="0.1" name="bmi" required>
            </div>
            <div class="input-group">
                <label>Diabetes Duration (Years):</label>
                <input type="number" name="diabetes_years" required>
            </div>
            <button type="submit" class="btn">Start AI Analysis</button>
        </form>
    </div>
</body>
</html>